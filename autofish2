local function openShop()
	if selling then return end
	selling = true

	local success, err = pcall(function()
		print("ĐI TỚI SHOP...")
        StatusText.Text = "Status: Going to shop..."
		smartMoveTo(SHOP_POS)
		
		task.wait(1)
		StatusText.Text = "Status: Selling..."
		print("MỞ SHOP...")
		if shopfish then
			shopfish.Visible = true
		end
		
		task.wait(2)

		for i = 1, math.floor(countFish / 1.2) do
			print("Selling fish:", i)
			task.wait(0.2)
			clickScale(833, 430)
			task.wait(0.25)

			clickScale(676, 809)
			task.wait(0.25)

			clickScale(825, 630)
			task.wait(0.2)
		end
		countFish = 0
		if shopfish then
			shopfish.Visible = false
		end
		countFish = 0
        StatusText.Text = "Status: Returning..."
		print("QUAY LẠI...")
		smartMoveTo(FISH_POS)
	end)

	if not success then
		warn("Shop error:", err)
	end

	countFish = 0
	selling = false
    task.wait(0.5)
end
local function isClose(a, b)
	return math.abs(a - b) < 0.02
end
-- 🎯 FISH STATE
 local fishBiting = false 
 local lastFinishClick = 0 
 local function checkFish()
	local size = status.Size 
	local xS, xO = size.X.Scale, size.X.Offset 
	local yS, yO = size.Y.Scale, size.Y.Offset

	if isClose(xS, 0.14) and xO == 230 then
		fishBiting = true
	elseif isClose(xS, 0.185) and xO == 250 then
		fishBiting = false
	else
		fishBiting = false
	end
end

local lastClickTime = 0

-- 🔁 LOOP
while task.wait(0.01) do
	if not auto then continue end
	-- 🛑 đang đi shop thì dừng toàn bộ
	if selling then
		task.wait(0.1)
		continue
	end
	
	-- so luong ca
	if countFish >= sellLimit and not selling then
	openShop()
	continue
end
	
	-- 🎣 AUTO START
	if startfishing and status then
		if startfishing.Visible and math.abs(status.BackgroundTransparency - 0.4) < 0.02 then
            StatusText.Text = "Status: Waiting to cast..."
			task.wait(0.44)		
			clickScale(852, 834)
			task.wait(0.2)
		end
	end

	checkFish()

	-- ✅ AUTO FINISH
	if not fishBiting then
		if isClose(status.Size.X.Scale, 0.185) then
            StatusText.Text = "Status: Caught!"
			task.wait(1.8)
			if tick() - lastFinishClick > 1 then			
				lastFinishClick = tick()			
				clickScale(1113, 342)
				countFish += 1
				FishText.Text = "Fish: "..countFish
			
			end
		end
	end

	-- AUTO FISH
if fishBiting and movingBar and targetBar then
	local xScale = movingBar.Size.X.Scale
	local center = targetBar.Position.X.Scale + targetBar.Size.X.Scale / 2
	
	local diff = center - xScale

	local absPos = movingBar.Parent.AbsolutePosition
	local absSize = movingBar.Parent.AbsoluteSize

	local x = absPos.X + absSize.X / 2
	local y = absPos.Y + absSize.Y / 2

	if diff > 0.008 then
		if tick() - lastClickTime > 0.02 then
			lastClickTime = tick()

			vim:SendMouseButtonEvent(x, y, 0, true, game, 0)
			task.wait(0.01)
			vim:SendMouseButtonEvent(x, y, 0, false, game, 0)
		end
	end

	StatusText.Text = "Status: Fishing..."
end
