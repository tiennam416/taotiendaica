local function clickScale(px, py)
	local viewport = camera.ViewportSize
	

	-- 🎯 convert pixel gốc (1920x1080) → scale
	local sx = px / 1920
	local sy = py / 1080

	local x = viewport.X * sx
	local y = viewport.Y * sy

	print(x,y)

	vim:SendMouseButtonEvent(x, y, 0, true, game, 0)
	task.wait(0.1)
	vim:SendMouseButtonEvent(x, y, 0, false, game, 0)
end

