-- ⚙️ BIẾN
local auto = false
local sellLimit = 10
local minimized = false

local function startObstacleJump()
	if obstacleConnection then return end

	obstacleConnection = RunService.Heartbeat:Connect(function()
		if not auto then return end

		-- Đảm bảo có character
		local character = player.Character or player.CharacterAdded:Wait()
		if not character then return end
		
		local humanoid = character:FindFirstChild("Humanoid")
		local hrp = character:FindFirstChild("HumanoidRootPart")
		if not humanoid or not hrp then return end

		raycastParams.FilterDescendantsInstances = {character}

		local basePos = hrp.Position
		local forward = hrp.CFrame.LookVector * 6

		local heights = {
			Vector3.new(0, -1.85, 0), -- chân
			Vector3.new(0, 0, 0),     -- thân
			Vector3.new(0, 2, 0),     -- đầu
		}

		for _, offset in ipairs(heights) do
			local origin = basePos + offset
			local result = workspace:Raycast(origin, forward, raycastParams)

			if result then
				local part = result.Instance
				
				if part and part.CanCollide then
					
					-- check tường cao
					local highCheck = workspace:Raycast(
						basePos + Vector3.new(0, 3.5, 0),
						forward,
						raycastParams
					)

					if highCheck and highCheck.Instance == part then
						-- ❌ tường cao → xoay
						hrp.CFrame = hrp.CFrame * CFrame.Angles(0, math.rad(20), 0)
						return
					end

					-- ✅ vật thấp → nhảy
					if tick() - lastJump > JUMP_COOLDOWN then
						lastJump = tick()
						humanoid.JumpPower = 58
						humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
						return
					end
				end
			end
		end
	end)
end

local function stopObstacleJump()
	if obstacleConnection then
		obstacleConnection:Disconnect()
		obstacleConnection = nil
	end
end

