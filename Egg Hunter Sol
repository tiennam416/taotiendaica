local function isEgg(v)
    if not v then return false end
    
    if v:IsA("BasePart") or v:IsA("Model") then
        if string.find(string.lower(v.Name), "egg") then
            return true
        end
    end

    return false
end

local function getEggPosition(egg)
    if egg:IsA("MeshPart") then
        return egg.Position
    elseif egg:IsA("Model") then
        local root = egg:FindFirstChild("HumanoidRootPart") or egg:FindFirstChildWhichIsA("BasePart")
        if root then
            return root.Position
        else
            return egg:GetPivot().Position  -- fallback
        end
    end
    return nil
end




local forbiddenZones = {
    {
        minX = -150,
        maxX = 20,
        minZ = -170,
        maxZ = -70
    },

    -- ✅ VÙNG MỚI BẠN YÊU CẦU
    {
        minX = 30,
        maxX = 239,
        minZ = -700,
        maxZ = -580
    },

	{
        minX = 514,
        maxX = 653,
        minZ = -270,
        maxZ = -114
    },

	{
		minX = 15,
		maxX = 65,
		minZ = -459,
		maxZ = -409
	}
}

local function isInForbiddenZone(pos)
    for _, zone in pairs(forbiddenZones) do
        if pos.X >= zone.minX and pos.X <= zone.maxX
        and pos.Z >= zone.minZ and pos.Z <= zone.maxZ then
            return true
        end
    end
    return false
end

local function createESP(egg)
    if not egg or egg:FindFirstChild("EggHighlight") then return end

    local pos = getEggPosition(egg) or egg:GetPivot().Position
    local nameLower = string.lower(egg.Name)

    local isPointEgg = string.find(nameLower, "point_egg")
    local isPotionEgg = string.find(nameLower, "potion")
    local isSpecialEgg = string.find(nameLower, "egg") and not isPointEgg and not isPotionEgg

    local inForbidden = isInForbiddenZone(pos) and isPointEgg

    -- ===== Highlight =====
    local highlight = Instance.new("Highlight")
    highlight.Name = "EggHighlight"

    if inForbidden then
        highlight.FillColor = Color3.fromRGB(255, 50, 50)
        highlight.OutlineColor = Color3.fromRGB(255, 0, 0)

    elseif isPotionEgg then
        highlight.FillColor = Color3.fromRGB(0, 255, 200)
        highlight.OutlineColor = Color3.fromRGB(0, 255, 150)

    elseif isPointEgg then
        highlight.FillColor = Color3.fromRGB(255, 255, 0)
        highlight.OutlineColor = Color3.fromRGB(255, 200, 0)

    else
        -- 🌈 trứng lạ / event
        highlight.FillColor = Color3.fromRGB(180, 0, 255)
        highlight.OutlineColor = Color3.fromRGB(255, 0, 255)
    end

    highlight.FillTransparency = 0.35
    highlight.OutlineTransparency = 0

    -- FIX lỗi model không có PrimaryPart
    if egg:IsA("Model") then
        highlight.Adornee = egg.PrimaryPart or egg:FindFirstChildWhichIsA("BasePart")
    else
        highlight.Adornee = egg
    end

    highlight.Parent = egg

    -- ===== Billboard =====
    local billboard = Instance.new("BillboardGui")
    billboard.Name = "EggESPBillboard"
    billboard.Size = UDim2.new(0, 140, 0, 45)
    billboard.AlwaysOnTop = true
    billboard.StudsOffset = Vector3.new(0, 3, 0)
    billboard.Parent = egg

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.TextStrokeTransparency = 0
    label.TextScaled = true
    label.Font = Enum.Font.GothamBold

    -- ===== TEXT =====
    if isPointEgg then
        local num = string.match(egg.Name, "(%d+)") or "?"
        if inForbidden then
            label.Text = "❌ Egg " .. num
            label.TextColor3 = Color3.fromRGB(255, 80, 80)
        else
            label.Text = "🥚 Egg " .. num
            label.TextColor3 = Color3.fromRGB(255, 255, 0)
        end

    elseif isPotionEgg then
        label.Text = "🧪 Potion Egg"
        label.TextColor3 = Color3.fromRGB(0, 255, 200)

    else
        label.Text = "🌈 Special Egg"
        label.TextColor3 = Color3.fromRGB(200, 100, 255)
    end

    label.Parent = billboard
end


local function clearESP()
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("MeshPart") and string.find(v.Name, "point_egg_") then
            local h = v:FindFirstChild("EggHighlight")
            local b = v:FindFirstChild("EggESPBillboard")

            if h then h:Destroy() end
            if b then b:Destroy() end
        end
    end
end

local function toggleESP()
    espEnabled = not espEnabled

    if espEnabled then
        print("🟡 ESP ON")
    else
        print("⚫ ESP OFF")
        clearESP()
    end
end


