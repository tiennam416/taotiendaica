-- ================== PATHFINDING & COLLECT ==================
findBestEgg = function()
    local closest, dist = nil, math.huge
    for _, v in pairs(workspace:GetChildren()) do
        if isEgg(v) then
            local pos = getEggPosition(v)
            if pos and not isInForbiddenZone(pos) then
                local d = (hrp.Position - pos).Magnitude
                if d < dist then
                    dist = d
                    closest = v
                end
            end
        end
    end
    return closest
end
local  eggCollected = 0
local function triggerProximityPrompt(egg)
    local prompt = egg:FindFirstChildOfClass("ProximityPrompt") or egg:FindFirstChild("ProximityPrompt", true)
    if prompt then
        prompt:InputHoldBegin()
        task.wait(0.12)
        prompt:InputHoldEnd()

        -- 🥚 TĂNG COUNT
        eggCollected += 1
        eggCounterLabel.Text = "🥚 Eggs Collected: "..eggCollected
    end
end
local function goToBestEgg()
    if not autoEggEnabled then return end
    local egg = findBestEgg()
    if not egg then return end

    local pos = getEggPosition(egg)
    if (hrp.Position - pos).Magnitude <= 4 then
        triggerProximityPrompt(egg)
        task.wait(0.8)
        return
    end

    local path = PathfindingService:CreatePath({
        AgentRadius = 3, AgentHeight = 6, AgentCanJump = true,
        WaypointSpacing = 3,
        Costs = { Water = math.huge, Tree = math.huge, bossPortal = 999999999, House = 999999999 }
    })

    local success = pcall(function()
        path:ComputeAsync(hrp.Position, pos + Vector3.new(0,3,0))
    end)

    if success and path.Status == Enum.PathStatus.Success then
        for _, wp in ipairs(path:GetWaypoints()) do
            if not autoEggEnabled then break end
            humanoid:MoveTo(wp.Position)
            if not humanoid.MoveToFinished:Wait(2.5) then break end
        end
    else
        humanoid:MoveTo(pos + Vector3.new(0,4,0))
    end
end

task.spawn(function()
    while true do
        if autoEggEnabled then
            goToBestEgg()
        end
        task.wait(0.7)
    end
end)

