local JUMP_COOLDOWN = 0.35
local raycastParams = RaycastParams.new()
raycastParams.FilterType = Enum.RaycastFilterType.Exclude
raycastParams.IgnoreWater = true

-- Obstacle Jump (dùng chung với Egg)
local function startObstacleJump()
    if obstacleConnection then
    obstacleConnection:Disconnect()
    obstacleConnection = nil
    end
    obstacleConnection = RunService.Heartbeat:Connect(function()
        if not (autoFishEnabled or autoEggEnabled) then return end

        local character = player.Character
        if not character then return end

        local humanoid = character:FindFirstChild("Humanoid")
        local hrp = character:FindFirstChild("HumanoidRootPart")
        if not humanoid or not hrp then return end

        -- ❗ FIX: check gần shop (fish)
        if autoFishEnabled then
            if (hrp.Position - SHOP_POS).Magnitude <= 6 then
                return
            end
        end

        -- ❗ FIX: check gần egg
        if autoEggEnabled then
            local egg = findBestEgg()
            if egg then
                local pos = getEggPosition(egg)
                if pos and (hrp.Position - pos).Magnitude <= 6 then
                    return
                end
            end
        end

        raycastParams.FilterDescendantsInstances = {character}

        local basePos = hrp.Position
        local forward = hrp.CFrame.LookVector * 6
        local heights = {
            Vector3.new(0,-1.85,0),
            Vector3.new(0,0,0),
            Vector3.new(0,2,0)
        }

        for _, offset in ipairs(heights) do
            local result = workspace:Raycast(basePos + offset, forward, raycastParams)
            if result and result.Instance.CanCollide then

                local highCheck = workspace:Raycast(basePos + Vector3.new(0,3.5,0), forward, raycastParams)
                if highCheck and highCheck.Instance == result.Instance then
                    hrp.CFrame = hrp.CFrame * CFrame.Angles(0, math.rad(20), 0)
                    return
                end

                if tick() - lastJump > JUMP_COOLDOWN then
                    lastJump = tick()
                    humanoid.JumpPower = 58
                    humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
                    return
                end
            end
        end
    end)
end

local function stopObstacleJump()
    if obstacleConnection then
        obstacleConnection:Disconnect()
        obstacleConnection = nil
    end
end
local currentPathParts = {}

local  function clearPath()
    for _, p in pairs(currentPathParts) do
        if p and p.Parent then
            p:Destroy()
        end
    end
    currentPathParts = {}
end

local function drawPath(waypoints)
    clearPath()

    for _, wp in ipairs(waypoints) do
        local part = Instance.new("Part")
        part.Size = Vector3.new(0.6, 0.6, 0.6)
        part.Shape = Enum.PartType.Ball
        part.Material = Enum.Material.Neon
        part.Color = Color3.fromRGB(0, 255, 200)
        part.Anchored = true
        part.CanCollide = false
        part.Position = wp.Position + Vector3.new(0, 0.5, 0)
        part.Parent = workspace

        table.insert(currentPathParts, part)
    end
end

local showPathEnabled = false

local function smartMoveTo(targetPos, retry)
    retry = retry or 0

    -- ❗ GIỚI HẠN RETRY
   if retry >= 10 then
    StatusLabel.Text = "Status: Stuck → Resetting..."

    if humanoid and humanoid.Health > 0 then
        humanoid.Health = 0
    end

    return
end
    local character = player.Character or player.CharacterAdded:Wait()
    local humanoid = character:WaitForChild("Humanoid")
    local hrp = character:WaitForChild("HumanoidRootPart")

    startObstacleJump()

    local function createPath()
        return PathfindingService:CreatePath({
            AgentRadius = 3,
            AgentHeight = 6,
            AgentCanJump = true,
            WaypointSpacing = 3,
            Costs = {
                Water = math.huge,
                Tree = math.huge,
                bossPortal = math.huge,
                House = math.huge
            }
        })
    end

    local function computePath(path)
        local ok = pcall(function()
            path:ComputeAsync(hrp.Position, targetPos)
        end)
        return ok and path.Status == Enum.PathStatus.Success
    end

    -- ================= RETRY PATH =================
    local path = createPath()
    if not computePath(path) then
        task.wait(0.25)

        path = createPath()
        if not computePath(path) then
            clearPath()
            StatusLabel.Text = "Status: Path failed → retrying..."

            local offset = Vector3.new(
                math.random(-12, 12),
                0,
                math.random(-12, 12)
            )

            task.wait(0.2)

            -- ✅ FIX: có retry
            return smartMoveTo(targetPos + offset, retry + 1)
        end
    end

    local waypoints = path:GetWaypoints()

    if showPathEnabled then
        drawPath(waypoints)
    else
        clearPath()
    end

    local lastPos = hrp.Position
    local stuckTime = 0

    for _, wp in ipairs(waypoints) do
        if not character or humanoid.Health <= 0 then return end
        if not (autoFishEnabled or autoEggEnabled) then return end

        humanoid:MoveTo(wp.Position)

        local reached = humanoid.MoveToFinished:Wait(1.5)
        local moved = (hrp.Position - lastPos).Magnitude

        -- ================= STUCK CHECK =================
        if moved < 0.55 or not reached then
            stuckTime += 1
        else
            stuckTime = 0
        end

        lastPos = hrp.Position

        -- ================= UNSTUCK FIX =================
        if stuckTime >= 2 then
            StatusLabel.Text = "Status: Unstucking..."

            humanoid.Jump = true
            task.wait(0.1)

            local side = Vector3.new(math.random(-1,1), 0, math.random(-1,1))
            if side.Magnitude == 0 then side = Vector3.new(1,0,0) end

            humanoid:MoveTo(hrp.Position + side.Unit * 6)
            humanoid.MoveToFinished:Wait(1)

            -- ✅ FIX: có retry
            return smartMoveTo(targetPos, retry + 1)
        end
    end

    -- ✅ FIX: tránh đứng yên sau khi đi xong
    humanoid:Move(Vector3.zero)
end
