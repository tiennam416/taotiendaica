-- ==================== RAYCAST CHỈ NHẢY KHI CANCOLLIDE = TRUE ====================
local raycastParams = RaycastParams.new()
raycastParams.FilterType = Enum.RaycastFilterType.Exclude
raycastParams.IgnoreWater = true

local lastJump = 0
local JUMP_COOLDOWN = 0.35

local function startObstacleJump()
    if obstacleConnection then return end

    raycastParams.FilterDescendantsInstances = {character}

    obstacleConnection = RunService.Heartbeat:Connect(function()
        if not enabled or not hrp or not humanoid then return end

        if tick() % 0.05 > 0.016 then return end

        local basePos = hrp.Position
        local forward = hrp.CFrame.LookVector * 6

        local heights = {
            Vector3.new(0, -1.85, 0), -- chân
            Vector3.new(0, 0, 0),  -- thân
            Vector3.new(0, 2, 0),  -- đầu
        }

        for _, offset in ipairs(heights) do
            local origin = basePos + offset
            local result = workspace:Raycast(origin, forward, raycastParams)

            if result then
                local part = result.Instance
                if part and part.CanCollide then

                    local highCheck = workspace:Raycast(
                        basePos + Vector3.new(0, 3.5, 0),
                        forward,
                        raycastParams
                    )

                    if highCheck and highCheck.Instance == part then
                        -- ❌ tường cao → xoay
                        hrp.CFrame = hrp.CFrame * CFrame.Angles(0, math.rad(20), 0)
                        return
                    end

                    if tick() - lastJump > JUMP_COOLDOWN then
                        lastJump = tick()

                        humanoid.JumpPower = 58
                        humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
                        return
                    end
                end
            end
        end
    end)
end
local function stopObstacleJump()
    if obstacleConnection then
        obstacleConnection:Disconnect()
        obstacleConnection = nil
    end
end

-- ==================== TÌM TRỨNG & PROMPT ====================



local function findBestEgg()
    local closestEgg = nil
    local closestDistance = math.huge

    for _, v in pairs(workspace:GetChildren()) do -- ❌ chỉ lấy object trực tiếp
        if isEgg(v) then
            
            local pos = getEggPosition(v)
            if not pos then continue end

            if isInForbiddenZone(pos) then
                continue
            end

            local dist = (hrp.Position - pos).Magnitude
            if dist < closestDistance then
                closestDistance = dist
                closestEgg = v
            end
        end
    end

    return closestEgg
end

local function triggerProximityPrompt(egg)
    if not egg then return end
    
    local prompt = egg:FindFirstChildOfClass("ProximityPrompt")
    
    -- Nếu không tìm thấy trực tiếp, tìm sâu hơn (đặc biệt với Model)
    if not prompt then
        prompt = egg:FindFirstChild("ProximityPrompt", true)
    end
    
    if prompt then
        prompt:InputHoldBegin()
        task.wait(0.12)
        prompt:InputHoldEnd()
        print("✅ Đã nhặt: " .. egg.Name)
    else
        print("⚠️ Không tìm thấy ProximityPrompt ở " .. egg.Name)
    end
end

