	local target = CFrame.new(
		hrp.Position + offset,
		hrp.Position
	)

	currentCFrame = currentCFrame:Lerp(target, 0.15)

	camera.CameraType = Enum.CameraType.Scriptable
	camera.CFrame = currentCFrame
