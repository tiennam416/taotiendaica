local function autoText(label, min, max)
    local cam = workspace.CurrentCamera
    
    local function update()
        local size = cam.ViewportSize
        local scaleX = size.X / 1920
        local scaleY = size.Y / 1080
        local scale = math.clamp(math.min(scaleX, scaleY), 0.6, 1.2)

        label.TextSize = math.floor(min + (max - min) * scale)
    end

    update()

    cam:GetPropertyChangedSignal("ViewportSize"):Connect(update)
end

