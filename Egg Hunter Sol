	if gpe then return end
	
	if input.UserInputType == Enum.UserInputType.MouseWheel then
		targetZoom = targetZoom - input.Position.Z * 5
		targetZoom = math.clamp(targetZoom, minZoom, maxZoom)
	end
end)

