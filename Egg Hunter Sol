local function scanEggs()
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("MeshPart") and string.find(v.Name, "point_egg_") then
            local pos = v.Position

            if isInForbiddenZone(pos) then
                createForbiddenESP(v)
                -- Xóa highlight bình thường nếu có
                if v:FindFirstChild("EggHighlight") then
                    v.EggHighlight:Destroy()
                end
            else
                if espEnabled then
                    createESP(v)
                else
                    if v:FindFirstChild("EggHighlight") then
                        v.EggHighlight:Destroy()
                    end
                    if v:FindFirstChild("EggESPBillboard") then
                        v.EggESPBillboard:Destroy()
                    end
                end
            end
        end
    end
end

-- ==================== FORBIDDEN ZONES ====================
local forbiddenZones = {
    {minX = -100, maxX = 20,   minZ = -145, maxZ = -70},
    {minX = 30,   maxX = 239,  minZ = -700, maxZ = -580},
    {minX = 15,   maxX = 65,   minZ = -459, maxZ = -409},
}

local function isInForbiddenZone(pos)
    for _, zone in ipairs(forbiddenZones) do
        if pos.X >= zone.minX and pos.X <= zone.maxX and
           pos.Z >= zone.minZ and pos.Z <= zone.maxZ then
            return true
        end
    end
    return false
end

