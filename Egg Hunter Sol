local map = workspace:WaitForChild("Map")
local waterFolder = map:WaitForChild("Miscs"):WaitForChild("WaterBlocks")
local treeFolder = map:WaitForChild("trees")
local bossPortal = workspace["Boss Portal"]
local house = workspace.Map.house

local function applyNoPath(folder, labelName)
    for _, part in pairs(folder:GetDescendants()) do
        if part:IsA("BasePart") then
            if not part:FindFirstChild("NoPath") then
                local modifier = Instance.new("PathfindingModifier")
                modifier.Name = "NoPath"
                modifier.Parent = part

                modifier.PassThrough = false
                modifier.Label = labelName
            end
        end
    end
end

applyNoPath(waterFolder, "Water")
applyNoPath(treeFolder, "Tree")
applyNoPath(bossPortal, "bossPortal")
applyNoPath(house, "House")

local currentTargetEgg = nil


local function goToBestEgg()
    if not enabled then return end

    
    currentTargetEgg = findBestEgg()

    local bestEgg = currentTargetEgg
    if not bestEgg then return end

    local eggPos = getEggPosition(bestEgg)
if not eggPos then return end

local dist = (hrp.Position - eggPos).Magnitude

-- Nếu gần thì nhặt
if dist <= 10 then
    triggerProximityPrompt(bestEgg)
    currentTargetEgg = nil

    humanoid:MoveTo(hrp.Position)
    task.wait(0.8)
    return
end

    -- Pathfinding giữ nguyên
    local path = PathfindingService:CreatePath({
        AgentRadius = 3,
        AgentHeight = 6,
        AgentCanJump = true,
        WaypointSpacing = 3,

        Costs = {
            Water = math.huge,
            Tree = math.huge,
            bossPortal = 9999999999,
            House = 999999999
        }
    })

    local success = pcall(function()
    path:ComputeAsync(hrp.Position, eggPos + Vector3.new(0, 3, 0))
end)

if success and path.Status == Enum.PathStatus.Success then
    for _, wp in ipairs(path:GetWaypoints()) do
        if not enabled then break end
        humanoid:MoveTo(wp.Position)
        if not humanoid.MoveToFinished:Wait(2.5) then break end
    end
else
    humanoid:MoveTo(eggPos + Vector3.new(0, 4, 0))
end
end

task.spawn(function()
    while true do
        if enabled and character and hrp and humanoid then
            goToBestEgg()
        end
        task.wait(0.7)
    end
end)

