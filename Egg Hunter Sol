local function createESP(egg)
    if egg:FindFirstChild("EggHighlight") then return end

    -- Highlight
    local highlight = Instance.new("Highlight")
    highlight.Name = "EggHighlight"
    highlight.FillColor = Color3.fromRGB(255, 255, 0)
    highlight.OutlineColor = Color3.fromRGB(255, 180, 0)
    highlight.FillTransparency = 0.35
    highlight.OutlineTransparency = 0
    highlight.Adornee = egg
    highlight.Parent = egg

    -- Billboard (text)
    local billboard = Instance.new("BillboardGui")
    billboard.Name = "EggESPBillboard"
    billboard.Size = UDim2.new(0, 120, 0, 40)
    billboard.AlwaysOnTop = true
    billboard.StudsOffset = Vector3.new(0, 2.5, 0)
    billboard.Parent = egg

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.TextColor3 = Color3.fromRGB(255, 255, 0)
    label.TextStrokeTransparency = 0
    label.TextScaled = true
    label.Font = Enum.Font.GothamBold

    local num = string.match(egg.Name, "point_egg_(%d+)")
    label.Text = "🥚 Egg " .. (num or "?")

    label.Parent = billboard
end

local function scanEggs()
    if not espEnabled then return end

    for _, v in pairs(workspace:GetDescendants()) do
        if (v:IsA("MeshPart") and string.find(v.Name, "point_egg_"))
		or v.Name == "random_potion_egg_1"
		or v.Name == "random_potion_egg_2" then
    		createESP(v)
end
    end
end

-- Auto update ESP
task.spawn(function()
    while true do
        if espEnabled then
            scanEggs()
        end
        task.wait(2)
    end
end)

