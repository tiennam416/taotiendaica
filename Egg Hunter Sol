    if espEnabled then
        espButton.Text = "ESP Egg: BẬT"
        espButton.BackgroundColor3 = Color3.fromRGB(0, 200, 100)
    else
        espButton.Text = "ESP Egg: TẮT"
        espButton.BackgroundColor3 = Color3.fromRGB(255, 80, 80)
    end
    scanEggs() -- cập nhật ngay lập tức
end

