local function isEgg(v)
    if not v or not v.Parent then return false end
    if not (v:IsA("BasePart") or v:IsA("Model")) then return false end
    
    local nameLower = string.lower(v.Name)
    if not string.find(nameLower, "egg") then return false end

    local prompt = v:FindFirstChildOfClass("ProximityPrompt") 
        or v:FindFirstChild("ProximityPrompt", true)

    if not prompt or not prompt.Enabled then return false end

    return true
end

