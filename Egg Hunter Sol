local function isSpotFree(pos, radius)
    radius = radius or 10

    for _, plr in pairs(game.Players:GetPlayers()) do
        if plr ~= player and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            local otherPos = plr.Character.HumanoidRootPart.Position
            if (otherPos - pos).Magnitude <= radius then
                return false
            end
        end
    end

    return true
end

local function getBestFishSpot()
    local closest = nil
    local dist = math.huge

    for _, pos in ipairs(FISH_SPOTS) do
        if isSpotFree(pos, 10) then
            local d = (hrp.Position - pos).Magnitude
            if d < dist then
                dist = d
                closest = pos
            end
        end
    end

    -- ❗ nếu tất cả đều bị chiếm → chọn đại 1 cái gần nhất
    if not closest then
        for _, pos in ipairs(FISH_SPOTS) do
            local d = (hrp.Position - pos).Magnitude
            if d < dist then
                dist = d
                closest = pos
            end
        end
    end

    return closest
end

