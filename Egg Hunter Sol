-- Định nghĩa getEggPosition
getEggPosition = function(egg)
    if egg:IsA("MeshPart") or egg:IsA("Part") then
        return egg.Position
    end
    
    if egg:IsA("Model") then
        local root = egg:FindFirstChild("HumanoidRootPart") 
                  or egg:FindFirstChildWhichIsA("BasePart")
        return root and root.Position or egg:GetPivot().Position
    end
    return egg.Position
end
-- Định nghĩa isInForbiddenZone
local function isInForbiddenZone(pos)
    for _, zone in ipairs(forbiddenZones) do
        if pos.X >= zone.minX and pos.X <= zone.maxX and pos.Z >= zone.minZ and pos.Z <= zone.maxZ then
            return true
        end
    end
    return false
end


-- Định nghĩa triggerProximityPrompt
local function triggerProximityPrompt(egg)
    local prompt = egg:FindFirstChildOfClass("ProximityPrompt") 
        or egg:FindFirstChild("ProximityPrompt", true)

    if prompt then
        fireproximityprompt(prompt)

        -- 🥚 TĂNG COUNT
        eggCollected += 1
        eggCounterLabel.Text = "🥚 Eggs Collected: "..eggCollected
    end
end

local function findSpecialEgg()
    for _, v in pairs(workspace:GetChildren()) do
        if isEgg(v) then
            local nameLower = string.lower(v.Name)

            -- ❗ chỉ lấy SPECIAL (không phải point/potion)
            if not string.find(nameLower, "point") then          
                
                local pos = getEggPosition(v)
                if pos and not isInForbiddenZone(pos) then
                    return v
                end
            end
        end
    end
    return nil
end

