    highlight.OutlineColor = info.color
    highlight.FillTransparency = 0.4
    highlight.OutlineTransparency = 0.1
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.Parent = egg

    -- Billboard GUI (thông tin)
