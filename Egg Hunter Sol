local fishBiting = false
local lastFinishClick = 0
local lastClickTime = 0

local function checkFish()
    if not status then return end
    local size = status.Size
    if math.abs(size.X.Scale - 0.14) < 0.02 and size.X.Offset == 230 then
        fishBiting = true
    elseif math.abs(size.X.Scale - 0.185) < 0.02 and size.X.Offset == 250 then
        fishBiting = false
    else
        fishBiting = false
    end
end

-- Main Fishing Loop
task.spawn(function()
    while true do
        task.wait(0.01)
        if not character or not character.Parent then continue end
        if not humanoid or humanoid.Health <= 0 then continue end
        if not autoFishEnabled or selling then continue end

        if fishCount >= sellLimit then
            openShop()
            continue
        end

        -- Auto Cast
        if startfishing and startfishing.Visible and status and math.abs(status.BackgroundTransparency - 0.4) < 0.02 then
            StatusLabel.Text = "Status: Casting..."
            task.wait(0.4)
            clickScale(852, 834)
            task.wait(0.25)
        end

        checkFish()

        -- Auto Finish
        if not fishBiting and status and math.abs(status.Size.X.Scale - 0.185) < 0.02 then
            StatusLabel.Text = "Status: Caught!"
            task.wait(1.7)
            if tick() - lastFinishClick > 1 then
                lastFinishClick = tick()
                clickScale(1113, 342)
                fishCount += 1
                FishCounterLabel.Text = "🎣 FISH: " .. fishCount
            end
        end

        -- Auto Click when fish biting
        if fishBiting and movingBar and targetBar then
            local xScale = movingBar.Size.X.Scale
            local center = targetBar.Position.X.Scale + targetBar.Size.X.Scale / 2
            local diff = center - xScale

            if diff > 0.008 then
                if tick() - lastClickTime > 0.018 then
                    lastClickTime = tick()
                    local absPos = movingBar.Parent.AbsolutePosition
                    local absSize = movingBar.Parent.AbsoluteSize
                    local x = absPos.X + absSize.X / 2
                    local y = absPos.Y + absSize.Y / 2
                    vim:SendMouseButtonEvent(x, y, 0, true, game, 0)
                    task.wait(0.01)
                    vim:SendMouseButtonEvent(x, y, 0, false, game, 0)
                end
            end
            StatusLabel.Text = "Status: Fishing..."
