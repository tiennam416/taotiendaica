-- ==================== AUTO JUMP ====================
local function startAutoJump()
    if jumpConnection then return end
    jumpConnection = RunService.Heartbeat:Connect(function()
        if not enabled or not humanoid then return end
        local state = humanoid:GetState()
        if state == Enum.HumanoidStateType.Running or 
           state == Enum.HumanoidStateType.RunningNoPhysics or 
           state == Enum.HumanoidStateType.Landed then
            humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
        end
    end)
end

local function stopAutoJump()
    if jumpConnection then
        jumpConnection:Disconnect()
        jumpConnection = nil
    end
end

-- ==================== TÌM TRỨNG GẦN NHẤT ====================
local function findNearestEgg()
    local minDistance = math.huge
    local nearestEgg = nil

    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("MeshPart") and string.find(v.Name, "point_egg_") then
            local dist = (hrp.Position - v.Position).Magnitude
            if dist < minDistance then
                minDistance = dist
                nearestEgg = v
            end
        end
    end
    return nearestEgg, minDistance
end

-- ==================== KÍCH HOẠT PROXIMITY PROMPT ====================
local function triggerProximityPrompt(egg)
    if not egg then return end
    local prompt = egg:FindFirstChildOfClass("ProximityPrompt")
    if not prompt then
        for _, obj in pairs(egg:GetDescendants()) do
            if obj:IsA("ProximityPrompt") then
                prompt = obj
                break
            end
        end
    end

    if prompt then
        prompt:InputHoldBegin()
        task.wait(0.15)
        prompt:InputHoldEnd()
    end
end

-- ==================== ĐI ĐẾN TRỨNG ====================
local function goToNearestEgg()
    if not enabled then return end
    
    local nearestEgg, distance = findNearestEgg()
    if not nearestEgg then return end

    if distance < 8 then
        triggerProximityPrompt(nearestEgg)
        humanoid:MoveTo(hrp.Position)
        task.wait(0.8)
        return
    end

    -- Pathfinding né hố
    local path = PathfindingService:CreatePath({
        AgentRadius = 2.5,
        AgentHeight = 6,
        AgentCanJump = true,
        WaypointSpacing = 4,
        Costs = { Water = math.huge }
    })

    local success = pcall(function()
        path:ComputeAsync(hrp.Position, nearestEgg.Position + Vector3.new(0, 3, 0))
    end)

    if success and path.Status == Enum.PathStatus.Success then
        for _, waypoint in ipairs(path:GetWaypoints()) do
            if not enabled then break end
            humanoid:MoveTo(waypoint.Position)
            if not humanoid.MoveToFinished:Wait(2) then break end
            if waypoint.Action == Enum.PathWaypointAction.Jump then
                humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
            end
        end
    else
        humanoid:MoveTo(nearestEgg.Position + Vector3.new(0, 4, 0))
    end
end

-- ==================== MAIN LOOP ====================
task.spawn(function()
    while true do
        if enabled and character and hrp and humanoid then
            goToNearestEgg()
        end
        task.wait(0.6)
    end
end)

-- ==================== XỬ LÝ TOGGLE ====================
local function toggleScript()
    enabled = not enabled
    
    if enabled then
        statusLabel.Text = "Trạng thái: ĐANG BẬT"
        statusLabel.TextColor3 = Color3.fromRGB(0, 255, 100)
        toggleButton.Text = "BẤM ĐỂ TẮT"
        toggleButton.BackgroundColor3 = Color3.fromRGB(255, 80, 80)
        startAutoJump()
        humanoid.JumpPower = 48
        print("✅ AUTO EGG + JUMP + NÉ HỐ ĐÃ BẬT")
    else
        statusLabel.Text = "Trạng thái: TẮT"
        statusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
        toggleButton.Text = "BẤM ĐỂ BẬT (N)"
        toggleButton.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
        stopAutoJump()
        if humanoid then
            humanoid:MoveTo(hrp.Position)
        end
        print("❌ AUTO EGG + JUMP + NÉ HỐ ĐÃ TẮT")
    end
end

-- Click nút
toggleButton.MouseButton1Click:Connect(toggleScript)

-- Phím N (vẫn giữ)
UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.N then
        toggleScript()
    end
end)

