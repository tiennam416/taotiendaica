local function createToggle(parent, text, posY, callback, default)

    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.8, 0, 0.12, 0)
    btn.Position = UDim2.new(0.05, 0, posY, 0)

    btn.BackgroundColor3 = Color3.fromRGB(40, 40, 55)
    btn.BackgroundTransparency = 0.4
    btn.Text = text
    btn.Font = Enum.Font.GothamSemibold
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.TextXAlignment = Enum.TextXAlignment.Left
    btn.TextScaled = false
    autoText(btn, 14, 20)

    local padding = Instance.new("UIPadding")
    padding.PaddingLeft = UDim.new(0, 10)
    padding.Parent = btn

    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 10)

    btn.Parent = parent

    local enabled = default or false

    -- 🔥 TOGGLE BG (ổn định cho mobile + PC)
    local toggleBG = Instance.new("Frame")
    toggleBG.Parent = btn
    toggleBG.Size = UDim2.new(0, 44, 0, 24)
    toggleBG.Position = UDim2.new(1, -10, 0.5, 0)
    toggleBG.AnchorPoint = Vector2.new(1, 0.5)

    toggleBG.BackgroundColor3 = enabled and Color3.fromRGB(0, 200, 120) or Color3.fromRGB(80, 80, 80)
    toggleBG.BorderSizePixel = 0

    Instance.new("UICorner", toggleBG).CornerRadius = UDim.new(1, 0)

    -- 🔥 đảm bảo không bị quá nhỏ / quá to trên mobile
    local sizeLimit = Instance.new("UISizeConstraint")
    sizeLimit.MinSize = Vector2.new(40, 20)
    sizeLimit.MaxSize = Vector2.new(80, 40)
    sizeLimit.Parent = toggleBG

    -- 🔥 CIRCLE (nút tròn)
    local circle = Instance.new("Frame")
    circle.Parent = toggleBG
    circle.Size = UDim2.new(0, 20, 0, 20)
    circle.AnchorPoint = Vector2.new(0.5, 0.5)

    circle.Position = enabled
        and UDim2.new(0.75, 0, 0.5, 0)
        or UDim2.new(0.25, 0, 0.5, 0)

    circle.BackgroundColor3 = Color3.new(1, 1, 1)
    circle.BorderSizePixel = 0

    Instance.new("UICorner", circle).CornerRadius = UDim.new(1, 0)

    -- 🔥 CLICK EVENT
    btn.MouseButton1Click:Connect(function()
        enabled = not enabled

        toggleBG.BackgroundColor3 = enabled
            and Color3.fromRGB(0, 200, 120)
            or Color3.fromRGB(80, 80, 80)

        circle:TweenPosition(
            enabled and UDim2.new(0.75, 0, 0.5, 0)
                    or UDim2.new(0.25, 0, 0.5, 0),
            Enum.EasingDirection.Out,
            Enum.EasingStyle.Quad,
            0.2,
            true
        )

        if callback then
            callback(enabled)
        end
    end)

    -- 🔥 init callback
    if callback then
        callback(enabled)
    end

    return btn
end
