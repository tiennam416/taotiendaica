-- ==================== RAYCAST CHỈ NHẢY KHI CANCOLLIDE = TRUE ====================
local function createStepUnderPlayer()
    if not hrp then return end

    local step = Instance.new("Part")
    step.Size = Vector3.new(5, 1.5, 5)
    step.Anchored = true
    step.CanCollide = true
    step.Material = Enum.Material.Neon
    step.Color = Color3.fromRGB(0, 255, 100)
    step.Transparency = 0.2

    step.Position = hrp.Position - Vector3.new(0, 3, 0)
    step.Parent = workspace

    task.delay(0.35, function()
        if step then step:Destroy() end
    end)
end


local function startObstacleJump()
    if obstacleConnection then return end

    local raycastParams = RaycastParams.new()
    raycastParams.FilterDescendantsInstances = {character}
    raycastParams.FilterType = Enum.RaycastFilterType.Exclude
    raycastParams.IgnoreWater = true

    obstacleConnection = RunService.Heartbeat:Connect(function()
        if not enabled or not hrp or not humanoid then return end

        local origin = hrp.Position + Vector3.new(0, -1.6, 0)
        local forward = hrp.CFrame.LookVector
        local hitDetected = false

        local directions = {
            forward * 5.2,
            (forward + Vector3.new(0.45, 0, 0)).Unit * 5.2,
            (forward - Vector3.new(0.45, 0, 0)).Unit * 5.2,
        }

        for _, dir in ipairs(directions) do
            local result = workspace:Raycast(origin, dir, raycastParams)

            if result and result.Instance then
                local part = result.Instance

                if part.CanCollide == true then
                    hitDetected = true

                    -- 🔍 CHECK TƯỜNG CAO
                    local highOrigin = origin + Vector3.new(0, 3.5, 0)
                    local highCheck = workspace:Raycast(highOrigin, dir, raycastParams)

                    if highCheck and highCheck.Instance and highCheck.Instance == part then
   					 -- 🧱 TƯỜNG CAO → GIỮ KHOẢNG CÁCH 5 STUD RỒI NHẢY
    				print("🧱 Tường cao → giữ khoảng cách + nhảy: " .. part.Name)

    				local direction = (hrp.Position - part.Position).Unit
   					 local targetPos = part.Position + direction * 5

    				-- Di chuyển lùi lại 1 chút trước khi nhảy
    				humanoid:MoveTo(targetPos)
    				humanoid.MoveToFinished:Wait(0.25)

    				createStepUnderPlayer()

    				humanoid.JumpPower = 60
   					humanoid:ChangeState(Enum.HumanoidStateType.Jumping)

    				task.wait(0.2)
    				return
				end

                    -- ✅ VẬT THẤP → NHẢY THƯỜNG
                    print("🟡 Vật thấp → nhảy: " .. part.Name)
                    humanoid.JumpPower = 58
                    humanoid:ChangeState(Enum.HumanoidStateType.Jumping)

                    task.wait(0.18)
                    break
                end
            end
        end

        if not hitDetected and math.random(1, 30) == 1 then
            print("🟢 Không có vật cản")
        end
    end)
end

local function stopObstacleJump()
    if obstacleConnection then
        obstacleConnection:Disconnect()
        obstacleConnection = nil
    end
end

-- ==================== TÌM TRỨNG & PROMPT ====================

local forbiddenZones = {
    {
        minX = -100,
        maxX = 20,
        minZ = -145,
        maxZ = -70
    },

    -- ✅ VÙNG MỚI BẠN YÊU CẦU
    {
        minX = 30,
        maxX = 235,
        minZ = -700,
        maxZ = -580
    },

	{
		minX = 15,
		maxX = 65,
		minZ = -459,
		maxZ = -409
	}
}

local function isInForbiddenZone(pos)
    for _, zone in pairs(forbiddenZones) do
        if pos.X >= zone.minX and pos.X <= zone.maxX
        and pos.Z >= zone.minZ and pos.Z <= zone.maxZ then
            return true
        end
    end
    return false
end

local function getEggPosition(obj)
    if obj:IsA("Model") then
        if obj.PrimaryPart then
            return obj.PrimaryPart.Position
        elseif obj:FindFirstChildWhichIsA("BasePart") then
            return obj:FindFirstChildWhichIsA("BasePart").Position
        end
    elseif obj:IsA("BasePart") then
        return obj.Position
    end
    return nil
end

local function isEgg(obj)
    return (
        (obj:IsA("MeshPart") and string.find(obj.Name, "point_egg_"))
        or obj.Name == "random_potion_egg_1"
        or obj.Name == "random_potion_egg_2"
    )
end

local function findBestEgg()
    local closestEgg = nil
    local closestDistance = math.huge

    for _, v in pairs(workspace:GetDescendants()) do
        if isEgg(v) then
            
            local pos = getEggPosition(v)
            if not pos then continue end

            -- ❌ bỏ vùng cấm
            if isInForbiddenZone(pos) then
                continue
            end

            local dist = (hrp.Position - pos).Magnitude

            if dist < closestDistance then
                closestDistance = dist
                closestEgg = v
            end
        end
    end

    return closestEgg
end

local function triggerProximityPrompt(egg)
    if not egg then return end

    local prompt = egg:FindFirstChildOfClass("ProximityPrompt")
        or egg:FindFirstChild("ProximityPrompt", true)

    if prompt then
        prompt:InputHoldBegin()
        task.wait(0.15)
        prompt:InputHoldEnd()
    end
end

---=============Né Nước,Cây===================================
local map = workspace:WaitForChild("Map")
local waterFolder = map:WaitForChild("Miscs"):WaitForChild("WaterBlocks")
local treeFolder = map:WaitForChild("trees")
local bossPortal = workspace["Boss Portal"]
local house = workspace.Map.house

local function applyNoPath(folder, labelName)
    for _, part in pairs(folder:GetDescendants()) do
        if part:IsA("BasePart") then
            if not part:FindFirstChild("NoPath") then
                local modifier = Instance.new("PathfindingModifier")
                modifier.Name = "NoPath"
                modifier.Parent = part

                modifier.PassThrough = false
                modifier.Label = labelName
            end
        end
    end
end

applyNoPath(waterFolder, "Water")
applyNoPath(treeFolder, "Tree")
applyNoPath(bossPortal, "bossPortal")
applyNoPath(house, "House")

local currentTargetEgg = nil


local function goToBestEgg()
    if not enabled then return end

    currentTargetEgg = findBestEgg()
    local bestEgg = currentTargetEgg
    if not bestEgg then return end

    -- 🔥 LẤY POSITION CHUẨN (fix Model)
    local pos = getEggPosition(bestEgg)
    if not pos then return end

    local dist = (hrp.Position - pos).Magnitude

    -- Nếu gần thì nhặt
    if dist <= 10 then
        triggerProximityPrompt(bestEgg)

        currentTargetEgg = nil
        humanoid:MoveTo(hrp.Position)
        task.wait(0.8)
        return
    end

    -- Pathfinding
    local path = PathfindingService:CreatePath({
        AgentRadius = 3,
        AgentHeight = 6,
        AgentCanJump = true,
        WaypointSpacing = 3,

        Costs = {
            Water = math.huge,
            Tree = math.huge,
            bossPortal = 9999999999,
            House = 999999999
        }
    })

    local success = pcall(function()
        path:ComputeAsync(hrp.Position, pos + Vector3.new(0, 3, 0))
    end)

    if success and path.Status == Enum.PathStatus.Success then
        for _, wp in ipairs(path:GetWaypoints()) do
            if not enabled then break end
            humanoid:MoveTo(wp.Position)
            if not humanoid.MoveToFinished:Wait(2.5) then break end
        end
    else
        humanoid:MoveTo(pos + Vector3.new(0, 4, 0))
    end
end

task.spawn(function()
    while true do
        if enabled and character and hrp and humanoid then
            goToBestEgg()
        end
        task.wait(0.7)
    end
end)

