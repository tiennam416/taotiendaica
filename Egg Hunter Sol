local function getEggInfo(egg)
    local nameLower = string.lower(egg.Name)
    local displayName = "Egg"
    local color = Color3.fromRGB(180, 0, 255)
    local emoji = "🥚"

    if string.find(nameLower, "point_egg") then
        local num = string.match(egg.Name, "(%d+)") or "?"
        displayName = "Point Egg " .. num
        emoji = "⭐"
        color = Color3.fromRGB(255, 215, 0)  -- Vàng đẹp
    elseif string.find(nameLower, "potion") then
        displayName = "Potion Egg"
        emoji = "🧪"
        color = Color3.fromRGB(0, 255, 180)
    elseif not string.find(nameLower, "point") and not string.find(nameLower, "potion") then
        displayName = "Special Egg"
        emoji = "🌈"
        color = Color3.fromRGB(255, 100, 255)
    end

    return {
        name = displayName,
        emoji = emoji,
        color = color
    }
end

local function createESP(egg)
