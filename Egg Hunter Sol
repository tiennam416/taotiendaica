-- ==================== RAYCAST CHỈ NHẢY KHI CANCOLLIDE = TRUE ====================
local function startObstacleJump()
    if obstacleConnection then return end

    local raycastParams = RaycastParams.new()
    raycastParams.FilterDescendantsInstances = {character}
    raycastParams.FilterType = Enum.RaycastFilterType.Exclude
    raycastParams.IgnoreWater = true

    obstacleConnection = RunService.Heartbeat:Connect(function()
        if not enabled or not hrp or not humanoid then return end

        local origin = hrp.Position + Vector3.new(0, 1.6, 0)   -- Từ bụng
        local forward = hrp.CFrame.LookVector
        local hitDetected = false

        -- 3 tia raycast
        local directions = {
            forward * 5.2,
            (forward + Vector3.new(0.45, 0, 0)).Unit * 5.2,
            (forward - Vector3.new(0.45, 0, 0)).Unit * 5.2,
        }

        for i, dir in ipairs(directions) do
            local result = workspace:Raycast(origin, dir, raycastParams)

            if result and result.Instance then
                local part = result.Instance
                
                -- KIỂM TRA CANCOLLIDE
                if part.CanCollide == true then
                    hitDetected = true
                    print(string.format("🔴 TIA %d PHÁT HIỆN VẬT CẢN CÓ CanCollide = true → Part: %s | Material: %s", 
                        i, part.Name, tostring(part.Material)))
                    
                    humanoid.JumpPower = 58
                    humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
                    task.wait(0.18)
                    break
                else
                    -- Debug: Phát hiện vật cản nhưng CanCollide = false
                    if math.random(1, 15) == 1 then
                        print("⚪ Phát hiện part nhưng CanCollide = false → Không nhảy: " .. part.Name)
                    end
                end
            end
        end

        if not hitDetected and math.random(1, 30) == 1 then
            print("🟢 Không có vật cản nào có CanCollide = true")
        end
    end)
end

local function stopObstacleJump()
    if obstacleConnection then
        obstacleConnection:Disconnect()
        obstacleConnection = nil
    end
end

-- ==================== TÌM TRỨNG & PROMPT ====================
local function findBestEgg()
    local bestEgg = nil
    local bestNumber = -1

    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("MeshPart") and string.find(v.Name, "point_egg_") then
            local numStr = string.match(v.Name, "point_egg_(%d+)")
            local num = numStr and tonumber(numStr) or 0
            if num > bestNumber then
                bestNumber = num
                bestEgg = v
            end
        end
    end
    return bestEgg
end

local function triggerProximityPrompt(egg)
    if not egg then return end
    local prompt = egg:FindFirstChildOfClass("ProximityPrompt") or egg:FindFirstChild("ProximityPrompt", true)
    if prompt then
        prompt:InputHoldBegin()
        task.wait(0.15)
        prompt:InputHoldEnd()
    end
end

local function goToBestEgg()
    if not enabled then return end
    local bestEgg = findBestEgg()
    if not bestEgg then return end

    local dist = (hrp.Position - bestEgg.Position).Magnitude
    if dist < 8 then
        triggerProximityPrompt(bestEgg)
        humanoid:MoveTo(hrp.Position)
        task.wait(0.8)
        return
    end

    local path = PathfindingService:CreatePath({
        AgentRadius = 3, AgentHeight = 6, AgentCanJump = true,
        WaypointSpacing = 3, Costs = {Water = math.huge}
    })

    local success = pcall(function()
        path:ComputeAsync(hrp.Position, bestEgg.Position + Vector3.new(0, 3, 0))
    end)

    if success and path.Status == Enum.PathStatus.Success then
        for _, wp in ipairs(path:GetWaypoints()) do
            if not enabled then break end
            humanoid:MoveTo(wp.Position)
            if not humanoid.MoveToFinished:Wait(2.5) then break end
        end
    else
        humanoid:MoveTo(bestEgg.Position + Vector3.new(0, 4, 0))
    end
end

task.spawn(function()
    while true do
        if enabled and character and hrp and humanoid then
            goToBestEgg()
        end
        task.wait(0.7)
    end
end)

-- ==================== TOGGLE ====================
local function toggleScript()
    enabled = not enabled
    if enabled then
        statusLabel.Text = "Trạng thái: ĐANG BẬT (Chỉ nhảy CanCollide=true)"
        statusLabel.TextColor3 = Color3.fromRGB(0, 255, 100)
        toggleButton.Text = "BẤM ĐỂ TẮT"
        toggleButton.BackgroundColor3 = Color3.fromRGB(255, 60, 60)
        startObstacleJump()
        print("✅ AUTO EGG + NHẢY CHỈ VẬT CẢN CÓ CANCOLLIDE = TRUE")
    else
        statusLabel.Text = "Trạng thái: TẮT"
        statusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
        toggleButton.Text = "BẤM ĐỂ BẬT (N)"
        toggleButton.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
        stopObstacleJump()
        print("❌ AUTO EGG ĐÃ TẮT")
    end
end

