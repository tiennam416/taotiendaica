-- ==================== RAYCAST CHỈ NHẢY KHI CANCOLLIDE = TRUE ====================
local function startObstacleJump()
    if obstacleConnection then return end

    local raycastParams = RaycastParams.new()
    raycastParams.FilterDescendantsInstances = {character}
    raycastParams.FilterType = Enum.RaycastFilterType.Exclude
    raycastParams.IgnoreWater = true

    obstacleConnection = RunService.Heartbeat:Connect(function()
        if not enabled or not hrp or not humanoid then return end

        local origin = hrp.Position + Vector3.new(0, -1.6, 0)   -- Từ bụng
        local forward = hrp.CFrame.LookVector
        local hitDetected = false

        -- 3 tia raycast
        local directions = {
            forward * 5.2,
            (forward + Vector3.new(0.45, 0, 0)).Unit * 5.2,
            (forward - Vector3.new(0.45, 0, 0)).Unit * 5.2,
        }

        for i, dir in ipairs(directions) do
    local result = workspace:Raycast(origin, dir, raycastParams)

    if result and result.Instance then
        local part = result.Instance
        
        if part.CanCollide == true then
            
            -- 🔍 CHECK TƯỜNG CAO
            local highOrigin = origin + Vector3.new(0, 3.5, 0) -- cao hơn đầu
            local highCheck = workspace:Raycast(highOrigin, dir, raycastParams)

            if highCheck and highCheck.Instance and highCheck.Instance == part then
                -- ❌ Đây là tường cao → KHÔNG NHẢY
                print("🧱 Tường cao detected → bỏ qua: " .. part.Name)

                -- 👉 Option: xoay nhẹ để né
                hrp.CFrame = hrp.CFrame * CFrame.Angles(0, math.rad(math.random(-40,40)), 0)
                
                return
            end

            -- ✅ Vật thấp → NHẢY
            print(string.format("🟡 Vật thấp → nhảy: %s", part.Name))
            humanoid.JumpPower = 58
            humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
            task.wait(0.18)
            break
        end
    end
end

        if not hitDetected and math.random(1, 30) == 1 then
            print("🟢 Không có vật cản nào có CanCollide = true")
        end
    end)
end

local function stopObstacleJump()
    if obstacleConnection then
        obstacleConnection:Disconnect()
        obstacleConnection = nil
    end
end

-- ==================== TÌM TRỨNG & PROMPT ====================

local forbiddenZones = {
    {
        minX = -100,
        maxX = 20,
        minZ = -145,
        maxZ = -70
    },

    -- ✅ VÙNG MỚI BẠN YÊU CẦU
    {
        minX = 30,
        maxX = 235,
        minZ = -700,
        maxZ = -580
    }
}

local function isInForbiddenZone(pos)
    for _, zone in pairs(forbiddenZones) do
        if pos.X >= zone.minX and pos.X <= zone.maxX
        and pos.Z >= zone.minZ and pos.Z <= zone.maxZ then
            return true
        end
    end
    return false
end
local waterFolder = workspace.Map.Miscs.WaterBlocks

local function isUnderWater(pos)
    for _, part in pairs(waterFolder:GetDescendants()) do
        if part:IsA("BasePart") then
            local size = part.Size
            local p = part.Position

            if pos.X >= p.X - size.X/2 and pos.X <= p.X + size.X/2
            and pos.Z >= p.Z - size.Z/2 and pos.Z <= p.Z + size.Z/2
            and pos.Y <= p.Y + size.Y/2 then
                return true
            end
        end
    end
    return false
end

local function findBestEgg()
    local closestEgg = nil
    local closestDistance = math.huge

    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("MeshPart") and string.find(v.Name, "point_egg_") then
            
            local pos = v.Position

            -- ❌ bỏ qua vùng cấm
            if isInForbiddenZone(pos) or isUnderWater(pos) then
    			continue
			end

            -- 📏 tính khoảng cách
            local dist = (hrp.Position - pos).Magnitude

            if dist < closestDistance then
                closestDistance = dist
                closestEgg = v
            end
        end
    end

    return closestEgg
end



local function triggerProximityPrompt(egg)
    if not egg then return end
    local prompt = egg:FindFirstChildOfClass("ProximityPrompt") or egg:FindFirstChild("ProximityPrompt", true)
    if prompt then
        prompt:InputHoldBegin()
        task.wait(0.15)
        prompt:InputHoldEnd()
    end
end

---=============Né Nước,Cây===================================
local map = workspace:WaitForChild("Map")

local treeFolder = map:WaitForChild("trees")
local bossPortal = workspace["Boss Portal"]
local house = workspace.Map.house

local function applyNoPath(folder, labelName)
    for _, part in pairs(folder:GetDescendants()) do
        if part:IsA("BasePart") then
            if not part:FindFirstChild("NoPath") then
                local modifier = Instance.new("PathfindingModifier")
                modifier.Name = "NoPath"
                modifier.Parent = part

                modifier.PassThrough = false
                modifier.Label = labelName
            end
        end
    end
end

applyNoPath(waterFolder, "Water")
applyNoPath(treeFolder, "Tree")
applyNoPath(bossPortal, "bossPortal")
applyNoPath(house, "House")

local currentTargetEgg = nil


local function goToBestEgg()
    if not enabled then return end

    
    currentTargetEgg = findBestEgg()

    local bestEgg = currentTargetEgg
    if not bestEgg then return end

    local dist = (hrp.Position - bestEgg.Position).Magnitude

    -- Nếu gần thì nhặt
    if dist <= 10 then
        triggerProximityPrompt(bestEgg)

        -- ✅ Sau khi nhặt xong → reset target để chọn trứng mới (lúc này mới ưu tiên trứng lớn hơn)
        currentTargetEgg = nil

        humanoid:MoveTo(hrp.Position)
        task.wait(0.8)
        return
    end

    -- Pathfinding giữ nguyên
    local path = PathfindingService:CreatePath({
        AgentRadius = 3,
        AgentHeight = 6,
        AgentCanJump = true,
        WaypointSpacing = 3,

        Costs = {
            Water = math.huge,
            Tree = math.huge,
            bossPortal = 9999999999,
            House = 999999999
        }
    })

    local success = pcall(function()
        path:ComputeAsync(hrp.Position, bestEgg.Position + Vector3.new(0, 3, 0))
    end)

    if success and path.Status == Enum.PathStatus.Success then
        for _, wp in ipairs(path:GetWaypoints()) do
    		if not enabled then break end

    		-- ❌ nếu waypoint nằm trong nước → bỏ path
    		if isUnderWater(wp.Position) then
       		print("🌊 Path bị nước chặn → bỏ")
        	return
    	end

    	humanoid:MoveTo(wp.Position)
    	if not humanoid.MoveToFinished:Wait(2.5) then break end
	end
    else
        humanoid:MoveTo(bestEgg.Position + Vector3.new(0, 4, 0))
    end
end

task.spawn(function()
    while true do
        if enabled and character and hrp and humanoid then
            goToBestEgg()
        end
        task.wait(0.7)
    end
end)

