-- Obstacle Jump (dùng chung với Egg)
local function startObstacleJump()
    if obstacleConnection then return end
    obstacleConnection = RunService.Heartbeat:Connect(function()
        if not (autoFishEnabled or autoEggEnabled) then return end

		-- ❗ FIX: nếu gần trứng thì không nhảy
		if autoEggEnabled then
    	local egg = findBestEgg()
    		if egg then
        		local pos = getEggPosition(egg)
        		if pos and (hrp.Position - pos).Magnitude <= 4 then
            		return -- đứng yên, không jump
        		end
    		end
		end
        
        local character = player.Character
        if not character then return end
        local humanoid = character:FindFirstChild("Humanoid")
        local hrp = character:FindFirstChild("HumanoidRootPart")
        if not humanoid or not hrp then return end

        raycastParams.FilterDescendantsInstances = {character}
        local basePos = hrp.Position
        local forward = hrp.CFrame.LookVector * 6
        local heights = {Vector3.new(0,-1.85,0), Vector3.new(0,0,0), Vector3.new(0,2,0)}

        for _, offset in ipairs(heights) do
            local result = workspace:Raycast(basePos + offset, forward, raycastParams)
            if result and result.Instance.CanCollide then
                local highCheck = workspace:Raycast(basePos + Vector3.new(0,3.5,0), forward, raycastParams)
                if highCheck and highCheck.Instance == result.Instance then
                    hrp.CFrame = hrp.CFrame * CFrame.Angles(0, math.rad(20), 0)
                    return
                end
                if tick() - lastJump > JUMP_COOLDOWN then
                    lastJump = tick()
                    humanoid.JumpPower = 58
                    humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
                    return
                end
            end
        end
    end)
end

local function stopObstacleJump()
    if obstacleConnection then
        obstacleConnection:Disconnect()
        obstacleConnection = nil
    end
end

local function smartMoveTo(targetPos)
    local character = player.Character or player.CharacterAdded:Wait()
    local humanoid = character:WaitForChild("Humanoid")
    local hrp = character:WaitForChild("HumanoidRootPart")

    startObstacleJump()

    local lastPos = hrp.Position
    local stuckTime = 0

    local function createPath()
        return PathfindingService:CreatePath({
            AgentRadius = 3,
            AgentHeight = 6,
            AgentCanJump = true,
            WaypointSpacing = 3,
            Costs = {
                Water = math.huge,
                Tree = math.huge,
                bossPortal = 999999999,
                House = 999999999
            }
        })
    end

    local path = createPath()

    local function compute()
        return pcall(function()
            path:ComputeAsync(hrp.Position, targetPos)
        end)
    end

    local success = compute()

    -- 🔁 retry nếu fail
    if not success or path.Status ~= Enum.PathStatus.Success then
        task.wait(0.3)
        path = createPath()
        success = compute()
    end

    if success and path.Status == Enum.PathStatus.Success then
        for _, wp in ipairs(path:GetWaypoints()) do
            if not (autoFishEnabled or autoEggEnabled) then break end

            humanoid:MoveTo(wp.Position)

            local reached = humanoid.MoveToFinished:Wait(2.5)

            -- ❌ nếu không tới → xử lý kẹt
            if not reached then
                -- kiểm tra stuck
                if (hrp.Position - lastPos).Magnitude < 1 then
                    stuckTime += 1
                else
                    stuckTime = 0
                end

                lastPos = hrp.Position

                -- 🧠 xử lý khi bị kẹt
                if stuckTime >= 2 then
                    humanoid.Jump = true
                    hrp.CFrame = hrp.CFrame * CFrame.new(0, 3, 0) -- nhấc lên nhẹ
                    task.wait(0.2)
                end

                -- 🔁 recompute path
                path = createPath()
                compute()
                break
            end
        end
    else
        -- 🚀 fallback thông minh hơn MoveTo
        hrp.CFrame = CFrame.new(targetPos + Vector3.new(0, 3, 0))
    end
end

