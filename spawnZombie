-- ================= LOGIC DỊCH CHUYỂN VÒNG LẶP =================
local function stopTeleport()
    running = false
end

local function startTeleport(team, zomType)
    stopTeleport()
    task.wait(0.05)
    running = true

    task.spawn(function()
        local toggle = true
        while running do
            local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
            local hrp = character:WaitForChild("HumanoidRootPart", 3)

            if hrp then
                local basePos = Positions[team].Base
                local zomPos = Positions[team][zomType]

                hrp.CFrame = CFrame.new(toggle and basePos or zomPos)
                toggle = not toggle
            end
            task.wait(0.1)
        end
    end)
end

RedButton.MouseButton1Click:Connect(function()
    startTeleport("RED", selectedRedZom)
end)

BlueButton.MouseButton1Click:Connect(function()
