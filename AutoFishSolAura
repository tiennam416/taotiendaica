-- ================== SHOP ==================
local function openShop()
    if selling then return end
    selling = true

    smartMoveTo(SHOP_POS)
    task.wait(1)

    if shopfish then shopfish.Visible = true end
    task.wait(1)

    for i = 1, fishCount do
        clickScale(833, 430)
        task.wait(0.2)
        clickScale(676, 809)
        task.wait(0.2)
        clickScale(825, 630)
        task.wait(0.4)
    end

    fishCount = 0

    if shopfish then shopfish.Visible = false end

    local spot = getBestFishSpot()
    if spot then
        smartMoveTo(spot)
    end

    selling = false
end

-- ================== CHECK FISH ==================
local fishBiting = false

local function checkFish()
    if not status then return end

    local size = status.Size
    local currentState = nil

    if math.abs(size.X.Scale - 0.14) < 0.02 then
        fishBiting = true
        currentState = "BITING"
    elseif math.abs(size.X.Scale - 0.185) < 0.02 then
        fishBiting = false
        currentState = "IDLE"
    end

    -- nếu state đổi → reset timer
    if currentState ~= lastFishState then
        lastFishState = currentState
        lastStateChange = tick()
    end
end

-- ================== MAIN LOOP ==================
task.spawn(function()
    while true do
        task.wait(0.01)

        if not autoFishEnabled or selling then continue end

        if fishCount >= sellLimit then
            openShop()
            continue
        end

        -- CAST
        if startfishing and startfishing.Visible then
            clickScale(852, 834)
            task.wait(0.3)
        end

        checkFish()

        -- FINISH
        if not fishBiting and status and math.abs(status.Size.X.Scale - 0.185) < 0.02 then
            task.wait(1.5)
            clickScale(1113, 342)
            fishCount += 1
        end

        -- CLICK BAR
        if fishBiting and movingBar and targetBar then
            local xScale = movingBar.Size.X.Scale
            local center = targetBar.Position.X.Scale + targetBar.Size.X.Scale / 2

            if center - xScale > 0.008 then
                local absPos = movingBar.Parent.AbsolutePosition
                local absSize = movingBar.Parent.AbsoluteSize

                local x = absPos.X + absSize.X / 2
                local y = absPos.Y + absSize.Y / 2

                vim:SendMouseButtonEvent(x, y, 0, true, game, 0)
                task.wait(0.01)
                vim:SendMouseButtonEvent(x, y, 0, false, game, 0)
            end
        end

        -- ❗ nếu bị đứng quá lâu → reset
        if tick() - lastStateChange > STATE_TIMEOUT then
            print("⚠️ Fishing bị treo → reset")

            if humanoid and humanoid.Health > 0 then
                humanoid.Health = 0
            end

            lastStateChange = tick()
        end
    end
end)

