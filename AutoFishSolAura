applyNoPath(treeFolder, "Tree")

-- ================= OBSTACLE JUMP =================
local obstacleConnection
local lastJump = 0
local JUMP_COOLDOWN = 0.35

local raycastParams = RaycastParams.new()
raycastParams.FilterType = Enum.RaycastFilterType.Exclude
raycastParams.IgnoreWater = true

local function startObstacleJump()
    if obstacleConnection then return end

    obstacleConnection = RunService.Heartbeat:Connect(function()
        if not autoFishEnabled then return end
        if not character or not hrp or not humanoid then return end

        raycastParams.FilterDescendantsInstances = {character}

        local basePos = hrp.Position
        local forward = hrp.CFrame.LookVector * 5

        local heights = {
            Vector3.new(0,-1.5,0),
            Vector3.new(0,0,0),
            Vector3.new(0,2,0)
        }

        for _, offset in ipairs(heights) do
            local result = workspace:Raycast(basePos + offset, forward, raycastParams)

            if result and result.Instance and result.Instance.CanCollide then
                -- nếu vật quá cao → xoay nhẹ
                local highCheck = workspace:Raycast(basePos + Vector3.new(0,3,0), forward, raycastParams)

                if highCheck and highCheck.Instance == result.Instance then
                    hrp.CFrame = hrp.CFrame * CFrame.Angles(0, math.rad(20), 0)
                    return
                end

                -- jump
                if tick() - lastJump > JUMP_COOLDOWN then
                    lastJump = tick()
                    humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
                    return
                end
            end
        end
    end)
end

local function stopObstacleJump()
    if obstacleConnection then
        obstacleConnection:Disconnect()
        obstacleConnection = nil
    end
end
