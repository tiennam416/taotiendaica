local treeFolder = map:WaitForChild("trees")

local function applyNoPath(folder, label)
    for _, part in pairs(folder:GetDescendants()) do
        if part:IsA("BasePart") and not part:FindFirstChild("NoPath") then
            local mod = Instance.new("PathfindingModifier")
            mod.Name = "NoPath"
            mod.Label = label
            mod.PassThrough = false
            mod.Parent = part
        end
    end
end

