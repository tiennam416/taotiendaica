-- ================== MOVE ==================
local function smartMoveTo(targetPos, retry)
    startObstacleJump()
    retry = retry or 0

    -- ❗ nếu retry quá nhiều → reset
    if retry >= 8 then
        print("⚠️ Stuck quá lâu → reset")
        if humanoid and humanoid.Health > 0 then
            humanoid.Health = 0
        end
        return
    end

    local path = PathfindingService:CreatePath({
        AgentRadius = 3,
        AgentHeight = 6,
        AgentCanJump = true,
        WaypointSpacing = 3,
        Costs = {
            Water = math.huge, 
            Tree = math.huge   
        }
    })

    local success = pcall(function()
        path:ComputeAsync(hrp.Position, targetPos)
    end)

    if not success or path.Status ~= Enum.PathStatus.Success then
        task.wait(0.2)

        -- random lệch để thoát kẹt
        local offset = Vector3.new(
            math.random(-10,10),
            0,
            math.random(-10,10)
        )

        return smartMoveTo(targetPos + offset, retry + 1)
    end

    local waypoints = path:GetWaypoints()

    local lastPos = hrp.Position
    local stuckCount = 0

    for _, wp in ipairs(waypoints) do
        if not autoFishEnabled then return end
        if not humanoid or humanoid.Health <= 0 then return end

        humanoid:MoveTo(wp.Position)

        local reached = humanoid.MoveToFinished:Wait(1.5)
        local moved = (hrp.Position - lastPos).Magnitude

        -- ❗ check bị kẹt
        if moved < 0.6 or not reached then
            stuckCount += 1
        else
            stuckCount = 0
        end

        lastPos = hrp.Position

        -- ❗ xử lý kẹt nhẹ
        if stuckCount >= 2 then
            print("🔄 Unstuck nhẹ...")

            humanoid.Jump = true
            task.wait(0.1)

            -- di chuyển lệch sang bên
            local side = Vector3.new(math.random(-1,1),0,math.random(-1,1))
            if side.Magnitude == 0 then side = Vector3.new(1,0,0) end

            humanoid:MoveTo(hrp.Position + side.Unit * 6)
            humanoid.MoveToFinished:Wait(1)

            return smartMoveTo(targetPos, retry + 1)
        end
    end

    -- tránh đứng đơ
    humanoid:Move(Vector3.zero)
    stopObstacleJump()
end

-- ================== FIND SPOT ==================
local function getBestFishSpot()
    local closest, dist = nil, math.huge
    for _, pos in ipairs(FISH_SPOTS) do
        local d = (hrp.Position - pos).Magnitude
        if d < dist then
            dist = d
            closest = pos
        end
    end
    return closest
end

